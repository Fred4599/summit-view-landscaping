---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const services = [
  "Landscape Install",
  "Hardscaping",
  "Sprinklers",
  "Maintenance",
  "Tree Care",
  "Fertilizer",
  "Spring & Fall Clean-Up",
  "Snow Removal",
  "Other",
];
---

<Layout
  title="Free Landscaping Estimate in Nampa & Treasure Valley | Summit View Landscape"
  description="Request your free, no-obligation landscaping estimate from Summit View Landscape in Nampa, Idaho. Serving Boise, Meridian, Eagle, Star, Caldwell, Kuna, and the Treasure Valley."
  canonicalPath="/book"
>
  <Navbar />
  <main>
    <!-- Page Hero -->
    <section class="relative flex items-center overflow-hidden pt-32 pb-20 sm:pt-40 sm:pb-28">
      <div class="absolute inset-0">
        <img
          src="/images/portfolio/gallery-paver-patio.jpg"
          alt="Beautiful paver patio installed by Summit View Landscape"
          class="h-full w-full object-cover"
          loading="eager"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-brand-black/85 via-brand-black/70 to-brand-black/50"></div>
      </div>
      <div class="relative mx-auto max-w-7xl px-6 lg:px-8">
        <div class="max-w-2xl">
          <p class="hero-fade font-heading text-sm font-bold uppercase tracking-widest text-brand-blue-light" style="--delay: 200ms">
            Get Started
          </p>
          <h1 class="hero-fade mt-3 font-heading text-h1 font-extrabold leading-tight text-white sm:text-display" style="--delay: 400ms">
            Book Your Free Estimate
          </h1>
          <p class="hero-fade mt-6 max-w-xl text-body-lg leading-relaxed text-white/80" style="--delay: 600ms">
            Tell us about your project and we'll get back to you within 24 hours with a free, no-obligation estimate. No pressure, just honest answers.
          </p>
        </div>
      </div>
    </section>

    <!-- Booking Form Section -->
    <section class="relative overflow-hidden bg-surface py-24">
      <div class="absolute inset-0 bg-gradient-to-br from-brand-blue/5 via-transparent to-brand-blue/5"></div>

      <div class="relative mx-auto max-w-7xl px-6 lg:px-8">
        <div class="grid gap-16 lg:grid-cols-5">
          <!-- Left column - info -->
          <div class="lg:col-span-2 animate-on-scroll">
            <p class="font-heading text-sm font-bold uppercase tracking-widest text-brand-blue">
              How It Works
            </p>
            <h2 class="mt-3 font-heading text-h2 font-extrabold text-brand-black">
              Simple &amp; Straightforward
            </h2>
            <p class="mt-4 text-body-lg leading-relaxed text-text-secondary">
              Getting started with Summit View is easy. Here's what to expect:
            </p>

            <!-- Steps -->
            <div class="mt-10 space-y-8">
              <div class="flex gap-4">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-brand-blue font-heading text-sm font-bold text-white">
                  1
                </div>
                <div>
                  <p class="font-heading text-body font-bold text-brand-black">Submit Your Request</p>
                  <p class="mt-1 text-sm leading-relaxed text-text-secondary">Fill out the form with your project details. The more info you share, the better we can help.</p>
                </div>
              </div>
              <div class="flex gap-4">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-brand-blue font-heading text-sm font-bold text-white">
                  2
                </div>
                <div>
                  <p class="font-heading text-body font-bold text-brand-black">We'll Reach Out</p>
                  <p class="mt-1 text-sm leading-relaxed text-text-secondary">Within 24 hours, we'll contact you to discuss your project and schedule a time to take a look at your property.</p>
                </div>
              </div>
              <div class="flex gap-4">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-brand-blue font-heading text-sm font-bold text-white">
                  3
                </div>
                <div>
                  <p class="font-heading text-body font-bold text-brand-black">Get Your Estimate</p>
                  <p class="mt-1 text-sm leading-relaxed text-text-secondary">We'll provide a clear, detailed estimate — no hidden fees, no surprises. If it works for you, we get to work.</p>
                </div>
              </div>
            </div>

            <!-- Contact info -->
            <div class="mt-12 space-y-6 border-t border-border pt-10">
              <p class="font-heading text-sm font-bold uppercase tracking-wider text-brand-black">
                Prefer to Reach Out Directly?
              </p>
              <div class="border-l-2 border-brand-blue pl-5">
                <p class="text-sm font-semibold text-text-muted">Call or Text</p>
                <a href="tel:+12086152104" class="text-body font-bold text-brand-black hover:text-brand-blue transition-colors duration-200 cursor-pointer">
                  (208) 615-2104
                </a>
              </div>
              <div class="border-l-2 border-brand-blue pl-5">
                <p class="text-sm font-semibold text-text-muted">Email Us</p>
                <a href="mailto:info@summitviewlandscape.co" class="text-body font-bold text-brand-black hover:text-brand-blue transition-colors duration-200 cursor-pointer">
                  info@summitviewlandscape.co
                </a>
              </div>
              <div class="border-l-2 border-brand-blue pl-5">
                <p class="text-sm font-semibold text-text-muted">Service Area</p>
                <p class="text-body font-bold text-brand-black">
                  Treasure Valley &amp; Surrounding Areas
                </p>
              </div>
            </div>
          </div>

          <!-- Right column - form -->
          <div class="lg:col-span-3 animate-on-scroll" style="--delay: 150ms">
            <form
              id="booking-form"
              class="rounded-2xl bg-card p-8 shadow-xl ring-1 ring-border sm:p-10"
            >
              <h3 class="font-heading text-h3 font-bold text-brand-black">Request Your Free Estimate</h3>
              <p class="mt-2 text-sm text-text-secondary">Fields marked with <span class="text-red-500">*</span> are required.</p>

              <div class="mt-8 grid gap-6 sm:grid-cols-2">
                <!-- First Name -->
                <div>
                  <label for="first-name" class="block text-sm font-semibold text-brand-black">
                    First Name <span class="text-red-500">*</span>
                  </label>
                  <input
                    type="text"
                    id="first-name"
                    name="first-name"
                    required
                    autocomplete="given-name"
                    class="mt-2 block w-full rounded-lg border border-border bg-surface px-4 py-3 text-body text-brand-black placeholder:text-text-muted transition-colors duration-200 focus:border-brand-blue focus:ring-2 focus:ring-brand-blue/20 focus:outline-none"
                    placeholder="John"
                  />
                </div>
                <!-- Last Name -->
                <div>
                  <label for="last-name" class="block text-sm font-semibold text-brand-black">
                    Last Name <span class="text-red-500">*</span>
                  </label>
                  <input
                    type="text"
                    id="last-name"
                    name="last-name"
                    required
                    autocomplete="family-name"
                    class="mt-2 block w-full rounded-lg border border-border bg-surface px-4 py-3 text-body text-brand-black placeholder:text-text-muted transition-colors duration-200 focus:border-brand-blue focus:ring-2 focus:ring-brand-blue/20 focus:outline-none"
                    placeholder="Smith"
                  />
                </div>
                <!-- Email -->
                <div>
                  <label for="email" class="block text-sm font-semibold text-brand-black">
                    Email <span class="text-red-500">*</span>
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    autocomplete="email"
                    class="mt-2 block w-full rounded-lg border border-border bg-surface px-4 py-3 text-body text-brand-black placeholder:text-text-muted transition-colors duration-200 focus:border-brand-blue focus:ring-2 focus:ring-brand-blue/20 focus:outline-none"
                    placeholder="john@example.com"
                  />
                </div>
                <!-- Phone -->
                <div>
                  <label for="phone" class="block text-sm font-semibold text-brand-black">
                    Phone <span class="text-red-500">*</span>
                  </label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    required
                    autocomplete="tel"
                    class="mt-2 block w-full rounded-lg border border-border bg-surface px-4 py-3 text-body text-brand-black placeholder:text-text-muted transition-colors duration-200 focus:border-brand-blue focus:ring-2 focus:ring-brand-blue/20 focus:outline-none"
                    placeholder="(208) 615-2104"
                  />
                </div>
                <!-- Address -->
                <div class="sm:col-span-2">
                  <label for="address" class="block text-sm font-semibold text-brand-black">
                    Property Address
                  </label>
                  <input
                    type="text"
                    id="address"
                    name="address"
                    autocomplete="street-address"
                    class="mt-2 block w-full rounded-lg border border-border bg-surface px-4 py-3 text-body text-brand-black placeholder:text-text-muted transition-colors duration-200 focus:border-brand-blue focus:ring-2 focus:ring-brand-blue/20 focus:outline-none"
                    placeholder="123 Main St, Boise, ID"
                  />
                </div>
                <!-- Service -->
                <div class="sm:col-span-2">
                  <label for="service" class="block text-sm font-semibold text-brand-black">
                    Service Interested In
                  </label>
                  <select
                    id="service"
                    name="service"
                    class="mt-2 block w-full rounded-lg border border-border bg-surface px-4 py-3 text-body text-brand-black transition-colors duration-200 focus:border-brand-blue focus:ring-2 focus:ring-brand-blue/20 focus:outline-none cursor-pointer"
                  >
                    <option value="">Select a service...</option>
                    {services.map((s) => <option value={s}>{s}</option>)}
                  </select>
                </div>
                <!-- Preferred Contact Method -->
                <div class="sm:col-span-2">
                  <label class="block text-sm font-semibold text-brand-black">
                    Preferred Contact Method
                  </label>
                  <div class="mt-3 flex flex-wrap gap-6">
                    <label class="flex items-center gap-2 cursor-pointer">
                      <input type="radio" name="contact-method" value="phone" class="h-4 w-4 border-border text-brand-blue focus:ring-brand-blue/20" checked />
                      <span class="text-body text-text-secondary">Phone Call</span>
                    </label>
                    <label class="flex items-center gap-2 cursor-pointer">
                      <input type="radio" name="contact-method" value="text" class="h-4 w-4 border-border text-brand-blue focus:ring-brand-blue/20" />
                      <span class="text-body text-text-secondary">Text Message</span>
                    </label>
                    <label class="flex items-center gap-2 cursor-pointer">
                      <input type="radio" name="contact-method" value="email" class="h-4 w-4 border-border text-brand-blue focus:ring-brand-blue/20" />
                      <span class="text-body text-text-secondary">Email</span>
                    </label>
                  </div>
                </div>
                <!-- Message -->
                <div class="sm:col-span-2">
                  <label for="message" class="block text-sm font-semibold text-brand-black">
                    Tell Us About Your Project
                  </label>
                  <textarea
                    id="message"
                    name="message"
                    rows="5"
                    class="mt-2 block w-full rounded-lg border border-border bg-surface px-4 py-3 text-body text-brand-black placeholder:text-text-muted transition-colors duration-200 focus:border-brand-blue focus:ring-2 focus:ring-brand-blue/20 focus:outline-none resize-y"
                    placeholder="Describe what you're looking for — size of yard, project ideas, timeline, budget range, etc. The more detail, the better we can help!"
                  ></textarea>
                </div>
              </div>

              <!-- Submit -->
              <button
                type="submit"
                class="mt-8 inline-flex w-full items-center justify-center rounded-lg bg-cta px-8 py-4 text-body font-bold text-white shadow-lg transition-all duration-200 hover:bg-cta-hover hover:shadow-xl cursor-pointer sm:w-auto"
              >
                Submit My Free Quote Request
              </button>

              <p class="mt-4 text-sm text-text-muted">
                We'll respond within 24 hours. No spam, ever.
              </p>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  const form = document.getElementById("booking-form") as HTMLFormElement;
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const btn = form.querySelector("button[type=submit]") as HTMLButtonElement;
    const originalText = btn.innerHTML;

    btn.disabled = true;
    btn.textContent = "Sending...";

    // Simulate send (replace with real form handler)
    setTimeout(() => {
      btn.textContent = "Quote Request Sent!";
      btn.classList.remove("bg-cta", "hover:bg-cta-hover");
      btn.classList.add("bg-green-600");
      form.reset();

      setTimeout(() => {
        btn.disabled = false;
        btn.innerHTML = originalText;
        btn.classList.add("bg-cta", "hover:bg-cta-hover");
        btn.classList.remove("bg-green-600");
      }, 3000);
    }, 1500);
  });
</script>
