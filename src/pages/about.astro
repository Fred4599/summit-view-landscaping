---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const values = [
  {
    title: "Quality Craftsmanship",
    description: "We don't cut corners. Every project gets the same level of care and attention to detail, whether it's a simple clean-up or a full backyard transformation.",
    icon: "M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z",
  },
  {
    title: "Honest Communication",
    description: "We show up when we say we will, keep you updated throughout every project, and give you straight answers — no runaround, no surprises on your invoice.",
    icon: "M8.625 9.75a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375m-13.5 3.01c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.184-4.183a1.14 1.14 0 01.778-.332 48.294 48.294 0 005.83-.498c1.585-.233 2.708-1.626 2.708-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z",
  },
  {
    title: "Community First",
    description: "We live and work right here in the Treasure Valley. Your neighbors are our neighbors, and we take pride in making our community a more beautiful place.",
    icon: "M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25",
  },
  {
    title: "Dependable Service",
    description: "We're not a one-and-done operation. We build lasting relationships with our clients through reliable, consistent service you can count on season after season.",
    icon: "M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z",
  },
];

const stats = [
  { number: "100+", label: "Projects Completed" },
  { number: "5.0", label: "Facebook Rating" },
  { number: "100%", label: "Locally Owned" },
  { number: "4", label: "Seasons of Service" },
];
---

<Layout title="About Us | Summit View Landscape" description="Learn about Summit View Landscape — a locally owned and operated landscaping company proudly serving Idaho's Treasure Valley with honest, quality outdoor services.">
  <Navbar />
  <main>
    <!-- Page Hero -->
    <section class="relative flex items-center overflow-hidden pt-32 pb-20 sm:pt-40 sm:pb-28">
      <div class="absolute inset-0">
        <img
          src="/images/portfolio/summit-view-truck.jpg"
          alt="Summit View Landscape branded work truck"
          class="h-full w-full object-cover"
          loading="eager"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-brand-black/85 via-brand-black/70 to-brand-black/50"></div>
      </div>
      <div class="relative mx-auto max-w-7xl px-6 lg:px-8">
        <div class="max-w-2xl">
          <p class="hero-fade font-heading text-sm font-bold uppercase tracking-widest text-brand-blue-light" style="--delay: 200ms">
            About Us
          </p>
          <h1 class="hero-fade mt-3 font-heading text-h1 font-extrabold leading-tight text-white sm:text-display" style="--delay: 400ms">
            Your Neighbors, Your Landscapers
          </h1>
          <p class="hero-fade mt-6 max-w-xl text-body-lg leading-relaxed text-white/80" style="--delay: 600ms">
            Summit View Landscape is a locally owned and operated landscaping company right here in Idaho, built on honest work and real relationships.
          </p>
        </div>
      </div>
    </section>

    <!-- Our Story -->
    <section class="bg-white py-24">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="grid items-center gap-16 lg:grid-cols-2">
          <div class="animate-on-scroll">
            <p class="font-heading text-sm font-bold uppercase tracking-widest text-brand-blue">
              Our Story
            </p>
            <h2 class="mt-3 font-heading text-h2 font-extrabold text-brand-black sm:text-h1">
              Built on Hard Work &amp; Handshakes
            </h2>
            <p class="mt-6 text-body-lg leading-relaxed text-text-secondary">
              Summit View Landscape started with a simple idea: deliver honest, high-quality outdoor services that make our neighbors proud of their properties. What began as a passion for transforming yards has grown into a full-service landscaping company trusted by homeowners and property managers across the Treasure Valley.
            </p>
            <p class="mt-4 text-body leading-relaxed text-text-secondary">
              We're not a big corporate operation — we're your neighbors. We live in the same community, shop at the same stores, and take pride in making Idaho a more beautiful place one yard at a time. Every project we take on, big or small, gets the same level of dedication and craftsmanship.
            </p>
            <p class="mt-4 text-body leading-relaxed text-text-secondary">
              Whether it's a full backyard transformation, a seasonal clean-up, or ongoing lawn maintenance, we treat every yard like it's our own. Our crew takes pride in showing up on time, communicating clearly, and leaving your property better than we found it.
            </p>
          </div>
          <div class="relative animate-on-scroll" style="--delay: 150ms">
            <div class="overflow-hidden rounded-2xl shadow-2xl">
              <img
                src="/images/portfolio/gallery-backyard.jpg"
                alt="Beautiful backyard landscape by Summit View"
                class="h-full w-full object-cover"
                loading="lazy"
                width="800"
                height="600"
              />
            </div>
            <div class="absolute -bottom-6 -left-6 rounded-xl bg-brand-blue p-6 text-white shadow-xl sm:-bottom-8 sm:-left-8">
              <p class="font-heading text-h2 font-extrabold leading-none">100+</p>
              <p class="mt-1 text-sm font-semibold text-white/80">Projects Completed</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="bg-brand-blue py-16">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="grid grid-cols-2 gap-8 lg:grid-cols-4">
          {stats.map((stat, i) => (
            <div class="animate-on-scroll text-center" style={`--delay: ${i * 100}ms`}>
              <p class="font-heading text-h1 font-extrabold text-white sm:text-display">{stat.number}</p>
              <p class="mt-2 text-sm font-semibold uppercase tracking-wider text-white/70">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Our Values -->
    <section class="bg-surface py-24">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center animate-on-scroll">
          <p class="font-heading text-sm font-bold uppercase tracking-widest text-brand-blue">
            What Drives Us
          </p>
          <h2 class="mt-3 font-heading text-h2 font-extrabold text-brand-black sm:text-h1">
            Our Values
          </h2>
          <p class="mt-4 text-body-lg leading-relaxed text-text-secondary">
            These aren't just words on a page — they're the principles we hold ourselves to on every single job.
          </p>
        </div>

        <div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
          {values.map((value, i) => (
            <div class="animate-on-scroll rounded-2xl bg-card p-8 shadow-sm ring-1 ring-border transition-all duration-300 hover:shadow-xl hover:-translate-y-1" style={`--delay: ${i * 100}ms`}>
              <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-brand-blue/10">
                <svg class="h-6 w-6 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d={value.icon} />
                </svg>
              </div>
              <h3 class="mt-6 font-heading text-h4 font-bold text-brand-black">{value.title}</h3>
              <p class="mt-3 text-body leading-relaxed text-text-secondary">{value.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Service Area -->
    <section class="bg-white py-24">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="grid items-center gap-16 lg:grid-cols-2">
          <div class="relative animate-on-scroll" style="--delay: 150ms">
            <div class="overflow-hidden rounded-2xl shadow-2xl">
              <img
                src="/images/portfolio/gallery-front-yard.jpg"
                alt="Front yard landscaping in the Treasure Valley"
                class="h-full w-full object-cover"
                loading="lazy"
                width="800"
                height="600"
              />
            </div>
          </div>
          <div class="animate-on-scroll">
            <p class="font-heading text-sm font-bold uppercase tracking-widest text-brand-blue">
              Where We Work
            </p>
            <h2 class="mt-3 font-heading text-h2 font-extrabold text-brand-black sm:text-h1">
              Proudly Serving the Treasure Valley
            </h2>
            <p class="mt-6 text-body-lg leading-relaxed text-text-secondary">
              We serve homeowners and businesses throughout the Treasure Valley and surrounding areas, including Boise, Meridian, Eagle, Star, Nampa, Caldwell, Kuna, and more.
            </p>
            <p class="mt-4 text-body leading-relaxed text-text-secondary">
              Not sure if we service your area? Give us a call — if we can make it work, we will.
            </p>

            <div class="mt-10 grid grid-cols-2 gap-x-8 gap-y-5">
              <div class="border-l-2 border-brand-blue pl-4">
                <p class="font-heading text-sm font-bold text-brand-black">Idaho Based</p>
                <p class="text-sm text-text-secondary">Locally owned &amp; operated</p>
              </div>
              <div class="border-l-2 border-brand-blue pl-4">
                <p class="font-heading text-sm font-bold text-brand-black">Licensed &amp; Insured</p>
                <p class="text-sm text-text-secondary">Fully covered for your peace of mind</p>
              </div>
              <div class="border-l-2 border-brand-blue pl-4">
                <p class="font-heading text-sm font-bold text-brand-black">Year-Round Service</p>
                <p class="text-sm text-text-secondary">Landscaping, maintenance &amp; snow removal</p>
              </div>
              <div class="border-l-2 border-brand-blue pl-4">
                <p class="font-heading text-sm font-bold text-brand-black">Free Estimates</p>
                <p class="text-sm text-text-secondary">No-obligation quotes on every project</p>
              </div>
            </div>

            <a
              href="/book"
              class="mt-10 inline-flex items-center gap-2 rounded-lg bg-cta px-6 py-3 text-body font-bold text-white shadow-lg transition-all duration-200 hover:bg-cta-hover hover:shadow-xl hover:-translate-y-0.5 cursor-pointer"
            >
              Get Your Free Estimate
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="bg-brand-black py-20">
      <div class="mx-auto max-w-4xl px-6 text-center lg:px-8 animate-on-scroll">
        <h2 class="font-heading text-h2 font-extrabold text-white sm:text-h1">
          Ready to Transform Your Outdoor Space?
        </h2>
        <p class="mt-4 text-body-lg leading-relaxed text-white/70">
          Let's talk about your project. Reach out today for a free, no-obligation estimate.
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href="/book"
            class="inline-flex items-center justify-center rounded-lg bg-cta px-8 py-4 text-body font-bold text-white shadow-lg transition-all duration-200 hover:bg-cta-hover hover:shadow-xl hover:-translate-y-0.5 cursor-pointer"
          >
            Request Your Free Estimate
          </a>
          <a
            href="tel:+12085551234"
            class="inline-flex items-center justify-center rounded-lg border-2 border-white/30 bg-white/5 px-8 py-4 text-body font-bold text-white backdrop-blur-sm transition-all duration-200 hover:border-white/50 hover:bg-white/10 cursor-pointer"
          >
            Call (208) 555-1234
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
