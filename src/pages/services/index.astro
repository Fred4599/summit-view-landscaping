---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { services } from "../../data/services";
---

<Layout title="Our Services | Summit View Landscape" description="Explore the full range of landscaping services offered by Summit View Landscape — from design and installation to maintenance and snow removal in Idaho's Treasure Valley.">
  <Navbar />
  <main>
    <!-- Page Hero -->
    <section class="relative flex items-center overflow-hidden pt-32 pb-20 sm:pt-40 sm:pb-28">
      <div class="absolute inset-0">
        <img
          src="/images/portfolio/landscape-design.jpg"
          alt="Professional landscape design by Summit View Landscape"
          class="h-full w-full object-cover"
          loading="eager"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-brand-black/85 via-brand-black/70 to-brand-black/50"></div>
      </div>
      <div class="relative mx-auto max-w-7xl px-6 lg:px-8">
        <div class="max-w-2xl">
          <p class="hero-fade font-heading text-sm font-bold uppercase tracking-widest text-brand-blue-light" style="--delay: 200ms">
            What We Do
          </p>
          <h1 class="hero-fade mt-3 font-heading text-h1 font-extrabold leading-tight text-white sm:text-display" style="--delay: 400ms">
            Our Services
          </h1>
          <p class="hero-fade mt-6 max-w-xl text-body-lg leading-relaxed text-white/80" style="--delay: 600ms">
            From full landscape transformations to weekly maintenance, we've got every corner of your outdoor space covered. Explore what we offer below.
          </p>
        </div>
      </div>
    </section>

    <!-- Services List -->
    <section class="bg-white py-24">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="space-y-24">
          {services.map((service, i) => (
            <div class={`animate-on-scroll grid items-center gap-12 lg:grid-cols-2 ${i % 2 === 1 ? 'lg:direction-rtl' : ''}`} style={`--delay: ${100}ms`}>
              <!-- Image -->
              <div class={`overflow-hidden rounded-2xl shadow-xl ${i % 2 === 1 ? 'lg:order-2' : ''}`}>
                <img
                  src={service.image}
                  alt={service.title}
                  class="h-full w-full object-cover aspect-[16/10]"
                  loading="lazy"
                  width="800"
                  height="500"
                />
              </div>
              <!-- Content -->
              <div class={i % 2 === 1 ? 'lg:order-1' : ''}>
                <a href={`/services/${service.slug}`} class="group">
                  <h2 class="font-heading text-h2 font-extrabold text-brand-black group-hover:text-brand-blue transition-colors">
                    {service.title}
                  </h2>
                </a>
                <p class="mt-4 text-body-lg leading-relaxed text-text-secondary">
                  {service.description}
                </p>
                <ul class="mt-8 grid gap-3 sm:grid-cols-2">
                  {service.details.map((detail) => (
                    <li class="flex items-start gap-3">
                      <svg class="mt-1 h-5 w-5 shrink-0 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                      </svg>
                      <span class="text-body text-text-secondary">{detail}</span>
                    </li>
                  ))}
                </ul>
                <div class="mt-8 flex flex-wrap items-center gap-4">
                  <a
                    href="/book"
                    class="inline-flex items-center gap-2 rounded-lg bg-cta px-6 py-3 text-body font-bold text-white shadow-lg transition-all duration-200 hover:bg-cta-hover hover:shadow-xl hover:-translate-y-0.5 cursor-pointer"
                  >
                    Get a Free Quote
                  </a>
                  <a
                    href={`/services/${service.slug}`}
                    class="inline-flex items-center gap-1 text-body font-semibold text-brand-blue transition-colors hover:text-brand-blue-dark"
                  >
                    Learn More
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="bg-brand-black py-20">
      <div class="mx-auto max-w-4xl px-6 text-center lg:px-8 animate-on-scroll">
        <h2 class="font-heading text-h2 font-extrabold text-white sm:text-h1">
          Not Sure What You Need?
        </h2>
        <p class="mt-4 text-body-lg leading-relaxed text-white/70">
          No problem — tell us about your property and we'll recommend the right services. Every project starts with a free, no-obligation estimate.
        </p>
        <a
          href="/book"
          class="mt-8 inline-flex items-center justify-center rounded-lg bg-cta px-8 py-4 text-body font-bold text-white shadow-lg transition-all duration-200 hover:bg-cta-hover hover:shadow-xl hover:-translate-y-0.5 cursor-pointer"
        >
          Request Your Free Estimate
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
