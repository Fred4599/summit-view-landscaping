---
// Portfolio gallery showcasing real project photos
const photos = [
  { src: "/images/portfolio/hero-patio-dusk.jpg", alt: "Paver patio with pergola and string lights at dusk" },
  { src: "/images/portfolio/gallery-xeriscaping.jpg", alt: "Luxury craftsman home with lush summer landscaping" },
  { src: "/images/portfolio/gallery-flower-garden.jpg", alt: "Spring flower beds with paver walkway and blossoming cherry tree" },
  { src: "/images/portfolio/gallery-paver-patio.jpg", alt: "Circular stone paver patio in backyard" },
  { src: "/images/portfolio/lawn-maintenance.jpg", alt: "Crew member mowing lawn during seasonal maintenance" },
  { src: "/images/portfolio/gallery-stone-path.jpg", alt: "Custom footbridge over stream in lush backyard" },
  { src: "/images/portfolio/gallery-raised-beds.jpg", alt: "Custom raised garden beds on paver patio" },
  { src: "/images/portfolio/gallery-front-yard.jpg", alt: "Colorful front yard garden with paver driveway edge" },
  { src: "/images/portfolio/gallery-flower-beds.jpg", alt: "Paver walkway with tulip flower beds and blossoming tree" },
  { src: "/images/portfolio/gallery-backyard.jpg", alt: "Lush backyard with mature shade trees and manicured lawn" },
  { src: "/images/portfolio/gallery-backyard-lawn.jpg", alt: "Manicured backyard with curved planting bed borders" },
  { src: "/images/portfolio/gallery-property.jpg", alt: "Luxury stone home with professional landscape installation" },
];
---

<section id="gallery" class="bg-white py-24">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Section header -->
    <div class="mx-auto max-w-2xl text-center animate-on-scroll">
      <p class="font-heading text-sm font-bold uppercase tracking-widest text-brand-blue">
        Our Work
      </p>
      <h2 class="mt-3 font-heading text-h2 font-extrabold text-brand-black sm:text-h1">
        Real Projects, Real Results
      </h2>
      <p class="mt-4 text-body-lg leading-relaxed text-text-secondary">
        Every photo is from an actual Summit View project right here in Idaho. No stock photos — just honest work we're proud of.
      </p>
    </div>

    <!-- Masonry-style gallery grid -->
    <div class="mt-16 columns-1 gap-4 sm:columns-2 lg:columns-3">
      {
        photos.map((photo, i) => (
          <div class="mb-4 break-inside-avoid overflow-hidden rounded-2xl shadow-sm ring-1 ring-border transition-all duration-300 hover:shadow-xl hover:-translate-y-1 animate-on-scroll" style={`--delay: ${(i % 3) * 100}ms`}>
            <img
              src={photo.src}
              alt={photo.alt}
              class="h-auto w-full object-cover"
              loading="lazy"
              width="400"
              height="300"
            />
          </div>
        ))
      }
    </div>

    <!-- Bottom CTA -->
    <div class="mt-16 text-center animate-on-scroll">
      <a
        href="#contact"
        class="inline-flex items-center justify-center rounded-lg bg-cta px-8 py-4 text-body font-bold text-white shadow-lg transition-all duration-200 hover:bg-cta-hover hover:shadow-xl hover:-translate-y-0.5 cursor-pointer"
      >
        Start Your Project
      </a>
    </div>
  </div>
</section>
