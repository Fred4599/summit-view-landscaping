---
// Navbar with logo, nav links, and CTA
const currentPath = Astro.url.pathname;
const isHome = currentPath === "/";
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-transparent"
>
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 lg:px-8">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3">
      <img
        src="/images/logo.webp"
        alt="Summit View Landscape logo"
        width="48"
        height="48"
        class="h-12 w-12 object-contain"
      />
      <div class="hidden sm:block">
        <span class="block font-heading text-lg font-bold leading-tight text-white">
          Summit View
        </span>
        <span class="block text-xs font-semibold uppercase tracking-widest text-white/80">
          Landscape
        </span>
      </div>
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden items-center gap-8 md:flex">
      <li>
        <a href="/about" class="text-sm font-semibold text-white/90 transition-colors duration-200 hover:text-white">
          About
        </a>
      </li>
      <li>
        <a href="/services" class="text-sm font-semibold text-white/90 transition-colors duration-200 hover:text-white">
          Services
        </a>
      </li>
      <li>
        <a href={isHome ? "#gallery" : "/#gallery"} class="text-sm font-semibold text-white/90 transition-colors duration-200 hover:text-white">
          Our Work
        </a>
      </li>
      <li>
        <a href={isHome ? "#testimonials" : "/#testimonials"} class="text-sm font-semibold text-white/90 transition-colors duration-200 hover:text-white">
          Testimonials
        </a>
      </li>
      <li>
        <a
          href="/book"
          class="inline-flex items-center rounded-lg bg-cta px-5 py-2.5 text-sm font-bold text-white shadow-lg transition-all duration-200 hover:bg-cta-hover hover:shadow-xl cursor-pointer"
        >
          Get a Free Quote
        </a>
      </li>
    </ul>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      type="button"
      class="inline-flex items-center justify-center rounded-lg p-2 text-white md:hidden cursor-pointer"
      aria-label="Open navigation menu"
      aria-expanded="false"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden">
    <div class="space-y-1 border-t border-white/10 px-6 pb-4 pt-2">
      <a href="/about" class="mobile-nav-link block rounded-lg px-3 py-2 text-base font-semibold text-white/90 hover:bg-white/10">
        About
      </a>
      <a href="/services" class="mobile-nav-link block rounded-lg px-3 py-2 text-base font-semibold text-white/90 hover:bg-white/10">
        Services
      </a>
      <a href={isHome ? "#gallery" : "/#gallery"} class="mobile-nav-link block rounded-lg px-3 py-2 text-base font-semibold text-white/90 hover:bg-white/10">
        Our Work
      </a>
      <a href={isHome ? "#testimonials" : "/#testimonials"} class="mobile-nav-link block rounded-lg px-3 py-2 text-base font-semibold text-white/90 hover:bg-white/10">
        Testimonials
      </a>
      <a
        href="/book"
        class="mobile-nav-link mt-2 block rounded-lg bg-cta px-3 py-2.5 text-center text-base font-bold text-white hover:bg-cta-hover cursor-pointer"
      >
        Get a Free Quote
      </a>
    </div>
  </div>
</header>

<script>
  // Navbar scroll effect
  const navbar = document.getElementById("navbar");

  function updateNavbar() {
    if (!navbar) return;
    if (window.scrollY > 50) {
      navbar.classList.remove("bg-transparent");
      navbar.classList.add("bg-brand-black/95", "backdrop-blur-md", "shadow-lg");
    } else {
      navbar.classList.add("bg-transparent");
      navbar.classList.remove("bg-brand-black/95", "backdrop-blur-md", "shadow-lg");
    }
  }

  window.addEventListener("scroll", updateNavbar, { passive: true });
  updateNavbar();

  // Mobile menu toggle
  const menuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");

  menuBtn?.addEventListener("click", () => {
    const isOpen = !mobileMenu?.classList.contains("hidden");
    mobileMenu?.classList.toggle("hidden");
    menuBtn.setAttribute("aria-expanded", String(!isOpen));
  });

  // Close mobile menu on link click
  document.querySelectorAll(".mobile-nav-link").forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu?.classList.add("hidden");
      menuBtn?.setAttribute("aria-expanded", "false");
    });
  });
</script>
