---
const testimonials = [
  {
    name: "Nate Burke",
    rating: 5,
    text: "Great quality workmanship! Micah was a great communicator, worked with me on a project that I was unsure about - and acted as a true expert. Kept a clean job site, and was very professional and courteous. Additionally, he went above and beyond by troubleshooting a potential issue (outside of the original project scope) to ensure the overall project was a success.",
  },
  {
    name: "Danielle McCauley",
    rating: 5,
    text: "I have a property management company and I hired Summit View Landscape for a big job. When I walked the property today, I was amazed. The work not only exceeded my expectations but I felt like they did more than we discussed. It's beautiful and perfect. I highly recommend.",
  },
  {
    name: "Kathy Westcott",
    rating: 5,
    text: "We used Summit View for a fall yard cleanup for bushes and trees that were out of control. They conquered the job in less than a day, saving us a full weekend or more of work and left everything clean and ready for winter. No call back to pick up the leftovers like other companies. I appreciated their responsiveness, knowledge and expertise!",
  },
  {
    name: "Kyle Sager",
    rating: 5,
    text: "Micah's expertise was incredibly helpful in solving a soil problem from the original landscape install crew. He helped me fix what my original landscaper failed to execute properly. Cleanup was great; pricing was very competitive. Micah has a degree in horticulture and landscape design, amongst other certifications and is highly knowledgeable, highly trained, and just a very nice dude as well. Highly recommend.",
  },
];
---

<section id="testimonials" class="bg-brand-black py-24">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Section header -->
    <div class="mx-auto max-w-2xl text-center animate-on-scroll">
      <p class="font-heading text-sm font-bold uppercase tracking-widest text-brand-blue-light">
        What Our Customers Say
      </p>
      <h2 class="mt-3 font-heading text-h2 font-extrabold text-white sm:text-h1">
        5-Star Reviews From Your Neighbors
      </h2>
      <p class="mt-4 text-body-lg leading-relaxed text-white/70">
        Don't just take our word for it. Here's what folks across Idaho are saying about Summit View.
      </p>
    </div>

    <!-- Testimonials grid -->
    <div class="mt-16 grid gap-8 md:grid-cols-2">
      {
        testimonials.map((t, i) => (
          <div class="animate-on-scroll rounded-2xl bg-white/5 p-8 ring-1 ring-white/10 backdrop-blur-sm" style={`--delay: ${i * 100}ms`}>
            <!-- Stars as text -->
            <div class="flex gap-1 text-brand-blue-light text-lg tracking-wider">
              {"★".repeat(t.rating)}
            </div>
            <!-- Quote -->
            <blockquote class="mt-4 text-body-lg leading-relaxed text-white/90">
              &ldquo;{t.text}&rdquo;
            </blockquote>
            <!-- Author -->
            <div class="mt-6 flex items-center gap-3">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-blue text-sm font-bold text-white">
                {t.name.charAt(0)}
              </div>
              <div>
                <p class="text-sm font-bold text-white">{t.name}</p>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Google Reviews CTA -->
    <div class="mt-12 text-center animate-on-scroll">
      <a
        href="https://www.google.com/maps/place/Summit+View+Landscape+LLC/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-lg border border-brand-blue bg-brand-blue px-6 py-3 text-sm font-bold text-white transition-all duration-200 hover:bg-brand-blue/80 cursor-pointer"
      >
        See All Reviews on Google
      </a>
    </div>
  </div>
</section>
