---
import { services } from "../data/services";

// Show first 6 on homepage
const displayServices = services.slice(0, 6);
---

<section id="services" class="bg-surface py-24">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Section header -->
    <div class="mx-auto max-w-2xl text-center animate-on-scroll">
      <p class="font-heading text-sm font-bold uppercase tracking-widest text-brand-blue">
        What We Do
      </p>
      <h2 class="mt-3 font-heading text-h2 font-extrabold text-brand-black sm:text-h1">
        Our Services
      </h2>
      <p class="mt-4 text-body-lg leading-relaxed text-text-secondary">
        From weekly mowing to full landscape overhauls, we've got every corner of your outdoor space covered.
      </p>
    </div>

    <!-- Services grid -->
    <div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        displayServices.map((service, i) => (
          <a href={`/services/${service.slug}`} class="animate-on-scroll group relative overflow-hidden rounded-2xl bg-card shadow-sm ring-1 ring-border transition-all duration-300 hover:shadow-xl hover:-translate-y-1" style={`--delay: ${i * 100}ms`}>
            <!-- Image -->
            <div class="aspect-[16/10] overflow-hidden">
              <img
                src={service.image}
                alt={service.title}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
                width="600"
                height="375"
              />
            </div>
            <!-- Content -->
            <div class="p-6">
              <h3 class="font-heading text-h4 font-bold text-brand-black group-hover:text-brand-blue transition-colors">
                {service.title}
              </h3>
              <p class="mt-3 text-body leading-relaxed text-text-secondary">
                {service.description}
              </p>
            </div>
          </a>
        ))
      }
    </div>

    <!-- Bottom CTA -->
    <div class="mt-16 text-center animate-on-scroll">
      <p class="text-body-lg text-text-secondary">
        Not sure what you need? No problem.
      </p>
      <a
        href="/book"
        class="mt-4 inline-flex items-center gap-2 font-heading text-body font-bold text-brand-blue transition-colors duration-200 hover:text-brand-blue-dark cursor-pointer"
      >
        Let's talk about your project
      </a>
    </div>
  </div>
</section>
